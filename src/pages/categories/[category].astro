---
import { queryCategories } from '@lib/query';
import { urlize } from '../../libs/strings';

export function getStaticPaths() {
  // 旧カテゴリURL → Channel URLへリダイレクト
  const categoryToChannel: Record<string, string> = {
    Tech: 'code',
    Idea: 'thought',
    Diary: 'life',
  };

  const categories = queryCategories();
  return categories.map((category) => ({
    params: { category: urlize(category.name) },
    props: { channelSlug: categoryToChannel[category.name] ?? urlize(category.name) },
  }));
}

const { channelSlug } = Astro.props;
const redirectUrl = `/channels/${channelSlug}`;
---

<!doctype html>
<html>
  <head>
    <meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
    <link rel="canonical" href={redirectUrl} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href={redirectUrl}>{redirectUrl}</a>...</p>
  </body>
</html>
