---
import { getTagByName } from '@lib/post';
import { urlize } from '../libs/strings';

export interface Props {
  name: string;
  count?: number;
  variant?: 'default' | 'detail';
}

const { name, count, variant = 'default' } = Astro.props;
const urlizedName = urlize(name);
const color = getTagByName(name)?.color ?? 'default';
---

{variant === 'detail' ? (
  <a
    class="text-[14px] leading-[normal] font-medium py-1 px-3 rounded-2xl inline-flex items-center border border-solid border-separator text-default bg-transparent hover:border-tertiary hover:bg-surface"
    href={`/tags/${urlizedName}`}
  >{name}{count && ` (${count})`}</a>
) : (
  <a
    style={`--color-tag-bg: var(--color-tag-bg-${color}); --color-tag-text: var(--color-tag-text-${color});`}
    class={`leading-relaxed text-xs inline-block px-2 rounded-sm bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] hover:shadow-tag`}
    href={`/tags/${urlizedName}`}
  >{name}{count && ` (${count})`}</a>
)}
