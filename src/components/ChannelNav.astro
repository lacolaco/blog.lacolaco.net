---
import { queryChannels } from '@lib/query';
import { urlize } from 'src/libs/strings';

export interface Props {
  class?: string;
  activePath: string;
}

const { class: className, activePath } = Astro.props;

const channels = queryChannels();
const items = [
  { name: 'すべて', path: '/' },
  ...channels.map((channel) => ({
    name: channel.name,
    path: `/channels/${urlize(channel.name)}`,
  })),
];
---

{/* モバイル: pill型ナビ */}
<div
  class:list={className}
  class="flex flex-row gap-x-2 h-[34px] text-xs font-semibold overflow-x-auto lg:hidden"
>
  {
    items.map((item) => {
      const isActive = item.path === activePath;
      return (
        <a
          href={item.path}
          class:list={[
            'flex items-center px-3 py-2 rounded-2xl border border-solid border-gray-300 leading-none whitespace-nowrap shrink-0',
            isActive ? 'bg-gray-500 text-white' : 'text-default bg-transparent hover:bg-gray-100',
          ]}
        >
          {item.name}
        </a>
      );
    })
  }
</div>

{/* PC: タブ型ナビ */}
<nav class="hidden lg:block bg-surface border-b border-medium sticky top-0 z-10">
  <div class="flex items-center max-w-(--breakpoint-lg) mx-auto px-10">
    {
      items.map((item) => {
        const isActive = item.path === activePath;
        return (
          <a
            href={item.path}
            class:list={[
              'flex items-center py-2.5 px-4 text-[14px] leading-[normal] whitespace-nowrap border-b-2 border-solid',
              isActive
                ? 'text-default font-bold border-b-current'
                : 'text-secondary font-medium border-b-transparent hover:text-default',
            ]}
          >
            {item.name}
          </a>
        );
      })
    }
    <span class="flex-1"></span>
    <slot />
  </div>
</nav>
