---
import { queryChannels } from '@lib/query';
import { urlize } from 'src/libs/strings';

export interface Props {
  activePath: string;
  /** RSSリンクのURL（PC表示時のみアイコン表示） */
  feedUrl?: string;
  class?: string;
}

const { activePath, feedUrl, class: className } = Astro.props;

const channels = queryChannels();
const items = [
  { name: 'すべて', path: '/' },
  ...channels.map((channel) => ({
    name: channel.name,
    path: `/channels/${urlize(channel.name)}`,
  })),
];
---

<nav
  aria-label="チャンネルナビゲーション"
  class:list={[
    'flex flex-row gap-2 items-center py-3 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden',
    className,
  ]}
>
  {
    items.map((item) => {
      const isActive = item.path === activePath;
      return (
        <a
          href={item.path}
          class:list={[
            'flex items-center h-[34px] px-3 text-xs font-semibold rounded-[20px] border border-solid leading-[12px] whitespace-nowrap shrink-0',
            isActive
              ? 'bg-[var(--color-text-default)] text-white border-[var(--color-text-default)]'
              : 'bg-default text-default border-[rgba(0,0,0,0.14)] hover:bg-surface',
          ]}
        >
          {item.name}
        </a>
      );
    })
  }
  {feedUrl && (
    <a href={feedUrl} title="RSS" target="_blank" rel="noopener noreferrer" class="hidden lg:flex text-tertiary p-2 rounded-md hover:text-secondary ml-auto">
      <span class="icon-[material-symbols--rss-feed-rounded] text-[16px]"></span>
    </a>
  )}
</nav>
