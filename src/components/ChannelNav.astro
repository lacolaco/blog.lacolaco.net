---
import { queryChannels } from '@lib/query';
import { urlize } from 'src/libs/strings';

export interface Props {
  activePath: string;
  /** PC用ナビ内に表示するRSSリンクのURL */
  feedUrl?: string;
  class?: string;
}

const { activePath, feedUrl, class: className } = Astro.props;

const channels = queryChannels();
const items = [
  { name: 'すべて', path: '/' },
  ...channels.map((channel) => ({
    name: channel.name,
    path: `/channels/${urlize(channel.name)}`,
  })),
];
---

{/* モバイル: pill型ナビ（note.com準拠: 34px高, 20px radius, 12px/600） */}
<nav
  class:list={["flex flex-row gap-2 items-center py-3 px-4 overflow-x-auto lg:hidden [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden", className]}
>
  {
    items.map((item) => {
      const isActive = item.path === activePath;
      return (
        <a
          href={item.path}
          class:list={[
            'flex items-center h-[34px] px-3 text-xs font-semibold rounded-[20px] border border-solid leading-[12px] whitespace-nowrap shrink-0',
            isActive
              ? 'bg-[var(--color-text-default)] text-white border-[var(--color-text-default)]'
              : 'bg-white text-default border-[rgba(0,0,0,0.14)] hover:bg-gray-50',
          ]}
        >
          {item.name}
        </a>
      );
    })
  }
</nav>

{/* PC: タブ型ナビ（リスト系ページ専用。z-10はページ内最上位。詳細ページでは使用しない） */}
<nav class:list={["hidden lg:block bg-surface border-b border-medium sticky top-0 z-10", className]}>
  <div class="flex items-center max-w-(--breakpoint-lg) mx-auto px-10">
    {
      items.map((item) => {
        const isActive = item.path === activePath;
        return (
          <a
            href={item.path}
            class:list={[
              'flex items-center py-2.5 px-4 text-[14px] leading-[normal] whitespace-nowrap border-b-2 border-solid',
              isActive
                ? 'text-default font-bold border-b-current'
                : 'text-secondary font-medium border-b-transparent hover:text-default',
            ]}
          >
            {item.name}
          </a>
        );
      })
    }
    <span class="flex-1"></span>
    {feedUrl && (
      <a href={feedUrl} title="RSS" target="_blank" rel="noopener noreferrer" class="flex text-tertiary p-2 rounded-md hover:text-secondary">
        <span class="icon-[material-symbols--rss-feed-rounded] text-[16px]"></span>
      </a>
    )}
  </div>
</nav>
