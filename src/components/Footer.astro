---
import { SITE_COPYRIGHT } from '../consts';

type Props = {
  class?: string;
};

const { class: className } = Astro.props;
---

<footer class:list={["max-w-(--breakpoint-lg) mx-auto px-4 lg:px-10", className]}>
  <div class="flex flex-col items-center justify-between pt-[32px] pb-[8px] text-sm text-default border-t border-medium lg:flex-row lg:text-xs lg:text-tertiary">
    <span>{SITE_COPYRIGHT}</span>
    <div class="hidden lg:flex gap-5">
      <a href="/index.xml" class="text-secondary no-underline hover:text-default hover:no-underline">RSS</a>
      <a href="/tags/" class="text-secondary no-underline hover:text-default hover:no-underline">Tags</a>
      <a href="https://lacolaco.net" target="_blank" rel="noopener noreferrer" class="text-secondary no-underline hover:text-default hover:no-underline">Profile</a>
    </div>
  </div>
</footer>
